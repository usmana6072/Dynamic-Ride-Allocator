<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #F7FAFF;"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dynamic_ride_allocator.Controllers.RiderControllers.CurrentRideController">

    <children>
        <HBox prefHeight="500.0" prefWidth="800.0">
            <children>

                <!-- ── SIDEBAR ── -->
                <VBox prefHeight="500.0" prefWidth="170.0" style="-fx-background-color: #1A3A5C;">
                    <Label text="🚗  RideBook"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-border-color: transparent transparent rgba(255,255,255,0.15) transparent;
                                  -fx-border-width: 1; -fx-padding: 14 16 18 16;" />
                    <Label fx:id="btnHome" onMouseClicked="#btnHomeAction" prefWidth="170.0"
                           text="🏠  Home"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnBookRide" onMouseClicked="#btnBookRideAction" prefWidth="170.0"
                           text="🚖  Book Ride"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnRideHistory" onMouseClicked="#btnRideHistoryAction" prefWidth="170.0"
                           text="📜  Ride History"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnCurrentRide" onMouseClicked="#btnCurrentRideAction" prefWidth="170.0"
                           text="🚘  Current Ride"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-background-color: rgba(255,255,255,0.15);
                                  -fx-border-color: #5DB3FF transparent transparent transparent;
                                  -fx-border-width: 0 0 0 3; -fx-padding: 10 16 10 13;" />
                    <Label fx:id="btnProfile" onMouseClicked="#btnProfileAction" prefWidth="170.0"
                           text="👤  Profile"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Label fx:id="btnLogout" onMouseClicked="#btnLogoutAction" prefWidth="170.0"
                           text="🚪  Logout"
                           style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;
                                  -fx-padding: 10 16 14 16; -fx-cursor: hand;" />
                </VBox>

                <!-- ── MAIN AREA ── -->
                <VBox prefHeight="500.0" prefWidth="530.0"
                      style="-fx-background-color: #F7FAFF; -fx-padding: 20 20 20 20;">

                    <Label text="Current Ride Status"
                           style="-fx-text-fill: #1A3A5C; -fx-font-size: 15px; -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                    </Label>

                    <VBox prefWidth="380.0"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                                 -fx-border-color: #E4EAF4; -fx-border-radius: 10;
                                 -fx-border-width: 0.8; -fx-padding: 16 18 16 18;">

                        <!-- Rider Header -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                            <children>
                                <StackPane prefWidth="46.0" prefHeight="46.0"
                                           style="-fx-background-color: #D0E8FF; -fx-background-radius: 50;">
                                    <Label fx:id="currentRiderAvatar" text="B"
                                           style="-fx-text-fill: #1A6DBB; -fx-font-size: 18px; -fx-font-weight: bold;" />
                                </StackPane>
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label fx:id="currentRiderName" text="Rider Name"
                                           style="-fx-text-fill: #1A3A5C; -fx-font-size: 13px; -fx-font-weight: bold;" />
                                    <Label fx:id="currentRiderVehicle" text="Vehicle • Plate"
                                           style="-fx-text-fill: #888888; -fx-font-size: 12px;" />
                                </VBox>
                                <Label fx:id="currentRideStatusBadge" text="  On the way  "
                                       style="-fx-background-color: #E6F0FF; -fx-text-fill: #1A5DB5;
                                              -fx-background-radius: 20; -fx-font-size: 11px;
                                              -fx-font-weight: bold; -fx-padding: 3 9 3 9;" />
                            </children>
                        </HBox>

                        <Separator style="-fx-opacity: 0.4;">
                            <VBox.margin><Insets bottom="12.0" /></VBox.margin>
                        </Separator>

                        <!-- Pickup -->
                        <Label text="PICKUP"
                               style="-fx-text-fill: #AAAAAA; -fx-font-size: 10px; -fx-font-weight: bold;">
                            <VBox.margin><Insets bottom="2.0" /></VBox.margin>
                        </Label>
                        <Label fx:id="currentPickupLabel" text="—"
                               style="-fx-text-fill: #1A3A5C; -fx-font-size: 13px;">
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </Label>

                        <!-- Destination -->
                        <Label text="DESTINATION"
                               style="-fx-text-fill: #AAAAAA; -fx-font-size: 10px; -fx-font-weight: bold;">
                            <VBox.margin><Insets bottom="2.0" /></VBox.margin>
                        </Label>
                        <Label fx:id="currentDestLabel" text="—"
                               style="-fx-text-fill: #1A3A5C; -fx-font-size: 13px;">
                            <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                        </Label>

                        <!-- ETA Info Box -->
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-background-color: #F0F6FF; -fx-background-radius: 8;
                                     -fx-padding: 10 12 10 12;">
                            <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                            <Label text="Estimated time remaining"
                                   style="-fx-text-fill: #1A3A5C; -fx-font-size: 12px;"
                                   HBox.hgrow="ALWAYS" />
                            <Label fx:id="currentETALabel" text="~-- min"
                                   style="-fx-text-fill: #1A6DBB; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        </HBox>

                        <!-- End Ride Button -->
                        <Button fx:id="btnEndRide" mnemonicParsing="false" text="End Ride"
                                onAction="#endRideAction"
                                prefWidth="344.0" prefHeight="36.0"
                                style="-fx-background-color: #D94040; -fx-text-fill: #FFFFFF;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 8; -fx-cursor: hand;" />
                    </VBox>

                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>