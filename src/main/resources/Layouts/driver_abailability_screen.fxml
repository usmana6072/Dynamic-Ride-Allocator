<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #F7FAFF;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dynamic_ride_allocator.Controllers.DriverControllers.AvailabilityScreenController">

    <children>
        <HBox prefHeight="500.0" prefWidth="700.0">
            <children>

                <!-- ── SIDEBAR ── -->
                <VBox prefHeight="500.0" prefWidth="170.0" style="-fx-background-color: #1A3A5C;">
                    <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;                              -fx-border-color: transparent transparent rgba(255,255,255,0.15) transparent;                              -fx-border-width: 1; -fx-padding: 14 16 18 16;" text="🚗  RideBook" />
                    <Label fx:id="btnHome" onMouseClicked="#btnHomeAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="🏠  Home" />
                    <Label fx:id="btnAvailability" onMouseClicked="#btnAvailabilityAction" prefWidth="170.0" style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; -fx-font-weight: bold;                              -fx-background-color: rgba(255,255,255,0.15);                              -fx-border-color: #5DB3FF transparent transparent transparent;                              -fx-border-width: 0 0 0 3; -fx-padding: 10 16 10 13;" text="📡  Availability" />
                    <Label fx:id="btnRequests" onMouseClicked="#btnRequestsAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="📋  Ride Requests" />
                    <Label fx:id="btnCurrentRide" onMouseClicked="#btnCurrentRideAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="🚘  Current Ride" />
                    <Label fx:id="btnProfile" onMouseClicked="#btnProfileAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="👤  Profile" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Label fx:id="btnLogout" onMouseClicked="#btnLogoutAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px; -fx-padding: 10 16 14 16; -fx-cursor: hand;" text="🚪  Logout" />
                </VBox>

                <!-- ── MAIN AREA ── -->
                <VBox alignment="CENTER" prefHeight="500.0" prefWidth="530.0" style="-fx-background-color: #F7FAFF; -fx-padding: 30 40 30 40;">

                    <Label style="-fx-text-fill: #1A3A5C; -fx-font-size: 15px; -fx-font-weight: bold;" text="Availability Status">
                        <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                    </Label>
                    <Label style="-fx-text-fill: #999999; -fx-font-size: 12px;" text="Toggle your status to accept ride requests">
                        <VBox.margin><Insets bottom="28.0" /></VBox.margin>
                    </Label>

                    <!-- Toggle Button -->
                    <ToggleButton fx:id="availabilityToggle" prefHeight="36.0" prefWidth="90.0" selected="true" style="-fx-background-color: #27A065;                           -fx-text-fill: #FFFFFF;                           -fx-font-size: 12px;                           -fx-font-weight: bold;                           -fx-background-radius: 20;                           -fx-cursor: hand;" text="ONLINE">
                        <VBox.margin><Insets bottom="8.0" /></VBox.margin>
                    </ToggleButton>

                    <Label fx:id="tvStaus" style="-fx-text-fill: #27A065; -fx-font-size: 13px; -fx-font-weight: bold;" text="You are currently ONLINE">
                        <VBox.margin><Insets bottom="28.0" /></VBox.margin>
                    </Label>

                    <!-- Location Card -->
                    <VBox prefWidth="300.0" style="-fx-background-color: #FFFFFF;                           -fx-background-radius: 10;                           -fx-border-color: #E4EAF4;                           -fx-border-radius: 10;                           -fx-border-width: 0.8;                           -fx-padding: 14 16 14 16;">
                        <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                        <children>
                            <Label style="-fx-text-fill: #666666; -fx-font-size: 11px; -fx-font-weight: bold;" text="Current Location">
                                <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                            </Label>
                            <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: #F0F6FF; -fx-background-radius: 8; -fx-padding: 10 12 10 12;">
                                <Label style="-fx-font-size: 14px;" text="📍" />
                        <ListView fx:id="locationsSet" prefHeight="30.0" prefWidth="200.0" />
                            </HBox>
                        </children>
                    </VBox>

                    <Button fx:id="btnUpdateLocation" mnemonicParsing="false" prefHeight="36.0" prefWidth="220.0" style="-fx-background-color: #1A6DBB;                               -fx-text-fill: #FFFFFF;                               -fx-font-size: 13px;                               -fx-font-weight: bold;                               -fx-background-radius: 8;                               -fx-cursor: hand;" text="Update Location" />
                </VBox>

            </children>
        </HBox>
    </children>
</AnchorPane>
