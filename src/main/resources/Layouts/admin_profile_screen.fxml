<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #F7FAFF;"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dynamic_ride_allocator.Controllers.AdminControllers.AdminProfileController">

    <children>
        <HBox prefHeight="500.0" prefWidth="700.0">
            <children>

                <!-- ── SIDEBAR ── -->
                <VBox prefHeight="500.0" prefWidth="170.0" style="-fx-background-color: #1A3A5C;">
                    <Label text="🚗  RideBook"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-border-color: transparent transparent rgba(255,255,255,0.15) transparent;
                                  -fx-border-width: 1; -fx-padding: 14 16 18 16;" />
                    <Label fx:id="btnDashboard" onMouseClicked="#btnDashboardAction" prefWidth="170.0"
                           text="📊  Dashboard"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnApproveRiders" onMouseClicked="#btnApproveRidersAction" prefWidth="170.0"
                           text="✅  Approve Riders"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnManageUsers" onMouseClicked="#btnManageUsersAction" prefWidth="170.0"
                           text="👥  Manage Users"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnProfile" onMouseClicked="#btnProfileAction" prefWidth="170.0"
                           text="👤  Profile"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-background-color: rgba(255,255,255,0.15);
                                  -fx-border-color: #5DB3FF transparent transparent transparent;
                                  -fx-border-width: 0 0 0 3; -fx-padding: 10 16 10 13;" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Label fx:id="btnLogout" onMouseClicked="#btnLogoutAction" prefWidth="170.0"
                           text="🚪  Logout"
                           style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;
                                  -fx-padding: 10 16 14 16; -fx-cursor: hand;" />
                </VBox>

                <!-- ── MAIN AREA ── -->
                <VBox prefHeight="500.0" prefWidth="530.0"
                      style="-fx-background-color: #F7FAFF; -fx-padding: 20 20 20 20;">

                    <Label text="Profile Settings"
                           style="-fx-text-fill: #1A3A5C; -fx-font-size: 15px; -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                    </Label>

                    <!-- Profile Card -->
                    <VBox prefWidth="360.0"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                                 -fx-border-color: #E4EAF4; -fx-border-radius: 10;
                                 -fx-border-width: 0.8; -fx-padding: 18 20 18 20;">

                        <!-- Avatar Row -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                            <children>
                                <StackPane prefWidth="46.0" prefHeight="46.0"
                                           style="-fx-background-color: #D0E8FF; -fx-background-radius: 50;">
                                    <Label text="A"
                                           style="-fx-text-fill: #1A6DBB; -fx-font-size: 18px; -fx-font-weight: bold;" />
                                </StackPane>
                                <VBox>
                                    <Label fx:id="profileNameDisplay"
                                           style="-fx-text-fill: #1A3A5C; -fx-font-size: 14px; -fx-font-weight: bold;"
                                           text="Administrator" />
                                    <Label fx:id="profileEmailDisplay"
                                           style="-fx-text-fill: #888888; -fx-font-size: 12px;"
                                           text="admin@ridebook.com" />
                                </VBox>
                            </children>
                        </HBox>

                        <Separator style="-fx-opacity: 0.4;">
                            <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                        </Separator>

                        <!-- Username -->
                        <Label text="Username"
                               style="-fx-text-fill: #666666; -fx-font-size: 11px; -fx-font-weight: bold;">
                            <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="fieldUsername" prefHeight="34.0"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: #D0D8E8;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-border-width: 1; -fx-font-size: 12px; -fx-padding: 5 10 5 10;">
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </TextField>

                        <!-- Email -->
                        <Label text="Email"
                               style="-fx-text-fill: #666666; -fx-font-size: 11px; -fx-font-weight: bold;">
                            <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="fieldEmail" prefHeight="34.0"
                                   style="-fx-background-color: #FFFFFF; -fx-border-color: #D0D8E8;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-border-width: 1; -fx-font-size: 12px; -fx-padding: 5 10 5 10;">
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </TextField>

                        <!-- Current Password -->
                        <Label text="Current Password"
                               style="-fx-text-fill: #666666; -fx-font-size: 11px; -fx-font-weight: bold;">
                            <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                        </Label>
                        <PasswordField fx:id="fieldCurrentPassword" prefHeight="34.0"
                                       promptText="••••••••"
                                       style="-fx-background-color: #FFFFFF; -fx-border-color: #D0D8E8;
                                              -fx-border-radius: 8; -fx-background-radius: 8;
                                              -fx-border-width: 1; -fx-font-size: 12px; -fx-padding: 5 10 5 10;">
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </PasswordField>

                        <!-- New Password -->
                        <Label text="New Password"
                               style="-fx-text-fill: #666666; -fx-font-size: 11px; -fx-font-weight: bold;">
                            <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                        </Label>
                        <PasswordField fx:id="fieldNewPassword" prefHeight="34.0"
                                       promptText="••••••••"
                                       style="-fx-background-color: #FFFFFF; -fx-border-color: #D0D8E8;
                                              -fx-border-radius: 8; -fx-background-radius: 8;
                                              -fx-border-width: 1; -fx-font-size: 12px; -fx-padding: 5 10 5 10;">
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </PasswordField>

                        <!-- Confirm Password -->
                        <Label text="Confirm Password"
                               style="-fx-text-fill: #666666; -fx-font-size: 11px; -fx-font-weight: bold;">
                            <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                        </Label>
                        <PasswordField fx:id="fieldConfirmPassword" prefHeight="34.0"
                                       promptText="••••••••"
                                       style="-fx-background-color: #FFFFFF; -fx-border-color: #D0D8E8;
                                              -fx-border-radius: 8; -fx-background-radius: 8;
                                              -fx-border-width: 1; -fx-font-size: 12px; -fx-padding: 5 10 5 10;">
                            <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                        </PasswordField>

                        <!-- Feedback Label -->
                        <Label fx:id="profileFeedback" text=""
                               style="-fx-font-size: 11px;">
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </Label>

                        <!-- Update Button -->
                        <Button mnemonicParsing="false" text="Update Profile"
                                onAction="#updateProfileAction"
                                prefWidth="320.0" prefHeight="36.0"
                                style="-fx-background-color: #1A6DBB; -fx-text-fill: #FFFFFF;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 8; -fx-cursor: hand;" />
                    </VBox>

                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>