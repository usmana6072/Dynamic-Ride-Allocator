<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #F7FAFF;"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dynamic_ride_allocator.Controllers.AdminControllers.ApproveDriverScreenController">

    <children>
        <HBox prefHeight="500.0" prefWidth="700.0">
            <children>

                <!-- ── SIDEBAR ── -->
                <VBox prefHeight="500.0" prefWidth="170.0" style="-fx-background-color: #1A3A5C;">
                    <Label text="🚗  RideBook"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-border-color: transparent transparent rgba(255,255,255,0.15) transparent;
                                  -fx-border-width: 1; -fx-padding: 14 16 18 16;" />
                    <Label fx:id="btnDashboard" onMouseClicked="#btnDashboardAction" prefWidth="170.0"
                           text="📊  Dashboard"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnApproveRiders" onMouseClicked="#btnApproveRidersAction" prefWidth="170.0"
                           text="✅  Approve Riders"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-background-color: rgba(255,255,255,0.15);
                                  -fx-border-color: #5DB3FF transparent transparent transparent;
                                  -fx-border-width: 0 0 0 3; -fx-padding: 10 16 10 13;" />
                    <Label fx:id="btnManageUsers" onMouseClicked="#btnManageUsersAction" prefWidth="170.0"
                           text="👥  Manage Users"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnProfile" onMouseClicked="#btnProfileAction" prefWidth="170.0"
                           text="👤  Profile"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Label fx:id="btnLogout" onMouseClicked="#btnLogoutAction" prefWidth="170.0"
                           text="🚪  Logout"
                           style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;
                                  -fx-padding: 10 16 14 16; -fx-cursor: hand;" />
                </VBox>

                <!-- ── MAIN AREA ── -->
                <VBox prefHeight="500.0" prefWidth="530.0"
                      style="-fx-background-color: #F7FAFF; -fx-padding: 20 20 20 20;">

                    <Label text="Rider Approval Requests"
                           style="-fx-text-fill: #1A3A5C; -fx-font-size: 15px; -fx-font-weight: bold;">
                        <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                    </Label>

                    <!-- Scrollable Table -->
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                style="-fx-background: transparent; -fx-background-color: transparent;
                                       -fx-border-color: transparent; -fx-focus-color: transparent;
                                       -fx-faint-focus-color: transparent;">
                        <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                                     -fx-border-color: #E4EAF4; -fx-border-radius: 10; -fx-border-width: 0.8;">

                            <!-- Table Header -->
                            <HBox style="-fx-background-color: #F0F5FF; -fx-background-radius: 10 10 0 0;
                                         -fx-padding: 8 10 8 10;
                                         -fx-border-color: transparent transparent #D8E8FF transparent;
                                         -fx-border-width: 1;">
                                <Label text="Rider Name" prefWidth="110.0"
                                       style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" />
                                <Label text="Email" prefWidth="130.0"
                                       style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" />
                                <Label text="Vehicle" prefWidth="70.0"
                                       style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" />
                                <Label text="License" prefWidth="90.0"
                                       style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" />
                                <Label text="Action"
                                       style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" />
                            </HBox>

                            <!-- Rows injected by controller -->
                            <VBox fx:id="ridersContainer" spacing="0" />

                        </VBox>
                    </ScrollPane>
                    <Button fx:id="btnApproveSelected"
                            text="Approve Selected Driver"
                            onAction="#handleApproveSelected"
                            style="-fx-background-color: #1A6DBB; -fx-text-fill: white;
               -fx-background-radius: 6; -fx-padding: 6 14;
               -fx-font-size: 11px; -fx-cursor: hand;">
                        <VBox.margin>
                            <Insets bottom="10"/>
                        </VBox.margin>
                    </Button>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>