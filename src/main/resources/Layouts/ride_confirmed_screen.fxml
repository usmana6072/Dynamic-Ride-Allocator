<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #F7FAFF;"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.dynamic_ride_allocator.Controllers.RiderControllers.RideConfirmedController">

    <children>
        <HBox prefHeight="500.0" prefWidth="700.0">
            <children>

                <!-- ── SIDEBAR ── -->
                <VBox prefHeight="500.0" prefWidth="170.0" style="-fx-background-color: #1A3A5C;">
                    <Label text="🚗  RideBook"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-border-color: transparent transparent rgba(255,255,255,0.15) transparent;
                                  -fx-border-width: 1; -fx-padding: 14 16 18 16;" />
                    <Label fx:id="btnHome" onMouseClicked="#btnHomeAction" prefWidth="170.0"
                           text="🏠  Home"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnBookRide" onMouseClicked="#btnBookRideAction" prefWidth="170.0"
                           text="🚖  Book Ride"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-background-color: rgba(255,255,255,0.15);
                                  -fx-border-color: #5DB3FF transparent transparent transparent;
                                  -fx-border-width: 0 0 0 3; -fx-padding: 10 16 10 13;" />
                    <Label fx:id="btnRideHistory" onMouseClicked="#btnRideHistoryAction" prefWidth="170.0"
                           text="📜  Ride History"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnCurrentRide" onMouseClicked="#btnCurrentRideAction" prefWidth="170.0"
                           text="🚘  Current Ride"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Label fx:id="btnProfile" onMouseClicked="#btnProfileAction" prefWidth="170.0"
                           text="👤  Profile"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;
                                  -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Label fx:id="btnLogout" onMouseClicked="#btnLogoutAction" prefWidth="170.0"
                           text="🚪  Logout"
                           style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;
                                  -fx-padding: 10 16 14 16; -fx-cursor: hand;" />
                </VBox>

                <!-- ── MAIN AREA ── -->
                <VBox prefHeight="500.0" prefWidth="530.0" alignment="CENTER"
                      style="-fx-background-color: #F7FAFF; -fx-padding: 30 80 30 80;">

                    <!-- Confirmed Badge -->
                    <Label text="  Ride Confirmed!  "
                           style="-fx-background-color: #E8FAF2; -fx-text-fill: #1A7A4A;
                                  -fx-background-radius: 20; -fx-font-size: 12px;
                                  -fx-font-weight: bold; -fx-padding: 5 14 5 14;">
                        <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                    </Label>

                    <!-- Rider Card -->
                    <VBox prefWidth="340.0"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;
                                 -fx-border-color: #E4EAF4; -fx-border-radius: 12;
                                 -fx-border-width: 0.8; -fx-padding: 20 20 20 20;">

                        <!-- Rider Avatar + Name -->
                        <VBox alignment="CENTER">
                            <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                            <StackPane prefWidth="64.0" prefHeight="64.0"
                                       style="-fx-background-color: #D0E8FF; -fx-background-radius: 50;">
                                <VBox.margin><Insets bottom="8.0" /></VBox.margin>
                                <Label fx:id="riderAvatarLabel" text="B"
                                       style="-fx-text-fill: #1A6DBB; -fx-font-size: 24px; -fx-font-weight: bold;" />
                            </StackPane>
                            <Label fx:id="confirmedRiderName" text="Rider Name"
                                   style="-fx-text-fill: #1A3A5C; -fx-font-size: 15px; -fx-font-weight: bold;">
                                <VBox.margin><Insets bottom="2.0" /></VBox.margin>
                            </Label>
                            <Label fx:id="confirmedRiderRating" text="⭐ 4.8 · 120 rides"
                                   style="-fx-text-fill: #888888; -fx-font-size: 12px;" />
                        </VBox>

                        <Separator style="-fx-opacity: 0.4;">
                            <VBox.margin><Insets bottom="12.0" top="12.0" /></VBox.margin>
                        </Separator>

                        <!-- Vehicle Info -->
                        <VBox style="-fx-background-color: #F7FAFF; -fx-background-radius: 8; -fx-padding: 10 12 10 12;">
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                            <Label text="VEHICLE"
                                   style="-fx-text-fill: #AAAAAA; -fx-font-size: 10px; -fx-font-weight: bold;">
                                <VBox.margin><Insets bottom="3.0" /></VBox.margin>
                            </Label>
                            <Label fx:id="confirmedVehicleInfo" text="Honda CB 125 • LHR-1234"
                                   style="-fx-text-fill: #1A3A5C; -fx-font-size: 13px;" />
                        </VBox>

                        <!-- ETA Row -->
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-border-color: transparent transparent #EEF2F8 transparent;
                                     -fx-border-width: 0 0 1 0; -fx-padding: 0 0 12 0;">
                            <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                            <Label text="Estimated Arrival"
                                   style="-fx-text-fill: #666666; -fx-font-size: 12px;"
                                   HBox.hgrow="ALWAYS" />
                            <Label fx:id="confirmedETA" text="~5 minutes"
                                   style="-fx-text-fill: #1A3A5C; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        </HBox>

                        <!-- Fare Row -->
                        <HBox alignment="CENTER_LEFT">
                            <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                            <Label text="Estimated Fare"
                                   style="-fx-text-fill: #666666; -fx-font-size: 12px;"
                                   HBox.hgrow="ALWAYS" />
                            <Label fx:id="confirmedFare" text="Rs 0"
                                   style="-fx-text-fill: #1A6DBB; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        </HBox>

                        <!-- Action Buttons -->
                        <HBox spacing="10.0">
                            <Button mnemonicParsing="false" text="Contact Rider"
                                    onAction="#contactRiderAction"
                                    prefHeight="34.0" prefWidth="150.0"
                                    style="-fx-background-color: #27A065; -fx-text-fill: #FFFFFF;
                                           -fx-font-size: 12px; -fx-font-weight: bold;
                                           -fx-background-radius: 8; -fx-cursor: hand;" />
                            <Button mnemonicParsing="false" text="Cancel Ride"
                                    onAction="#cancelRideAction"
                                    prefHeight="34.0" prefWidth="150.0"
                                    style="-fx-background-color: #D94040; -fx-text-fill: #FFFFFF;
                                           -fx-font-size: 12px; -fx-font-weight: bold;
                                           -fx-background-radius: 8; -fx-cursor: hand;" />
                        </HBox>

                    </VBox>
                </VBox>

            </children>
        </HBox>
    </children>
</AnchorPane>