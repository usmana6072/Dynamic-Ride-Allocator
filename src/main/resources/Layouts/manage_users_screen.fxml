<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #F7FAFF;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dynamic_ride_allocator.Controllers.AdminControllers.ManageUsersScreenController">

    <children>
        <HBox prefHeight="500.0" prefWidth="700.0">
            <children>

                <!-- ── SIDEBAR ── -->
                <VBox prefHeight="500.0" prefWidth="170.0" style="-fx-background-color: #1A3A5C;">
                    <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;                                   -fx-border-color: transparent transparent rgba(255,255,255,0.15) transparent;                                   -fx-border-width: 1; -fx-padding: 14 16 18 16;" text="🚗  RideBook" />
                    <Label fx:id="btnDashboard" onMouseClicked="#btnDashboardAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;                                   -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="📊  Dashboard" />
                    <Label fx:id="btnApproveRiders" onMouseClicked="#btnApproveRidersAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;                                   -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="✅  Approve Riders" />
                    <Label fx:id="btnManageUsers" onMouseClicked="#btnManageUsersAction" prefWidth="170.0" style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; -fx-font-weight: bold;                                   -fx-background-color: rgba(255,255,255,0.15);                                   -fx-border-color: #5DB3FF transparent transparent transparent;                                   -fx-border-width: 0 0 0 3; -fx-padding: 10 16 10 13;" text="👥  Manage Users" />
                    <Label fx:id="btnProfile" onMouseClicked="#btnProfileAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;                                   -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="👤  Profile" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Label fx:id="btnLogout" onMouseClicked="#btnLogoutAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;                                   -fx-padding: 10 16 14 16; -fx-cursor: hand;" text="🚪  Logout" />
                </VBox>

                <!-- ── MAIN AREA ── -->
                <VBox prefHeight="500.0" prefWidth="530.0" style="-fx-background-color: #F7FAFF; -fx-padding: 20 20 20 20;">

                    <Label style="-fx-text-fill: #1A3A5C; -fx-font-size: 15px; -fx-font-weight: bold;" text="User Management">
                        <VBox.margin><Insets bottom="12.0" /></VBox.margin>
                    </Label>

                    <!-- Tab Bar -->
                    <HBox style="-fx-border-color: transparent transparent #E0E8F5 transparent;                                  -fx-border-width: 1;">
                        <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                        <children>
                            <Label fx:id="tabRiders" style="-fx-text-fill: #1A6DBB; -fx-font-size: 12px; -fx-font-weight: bold;                                           -fx-border-color: transparent transparent #1A6DBB transparent;                                           -fx-border-width: 0 0 2 0; -fx-padding: 9 18 9 18; -fx-cursor: hand;" text="Riders" />
                            <Label fx:id="tabDrivers"  style="-fx-text-fill: #888888; -fx-font-size: 12px;                                           -fx-padding: 9 18 9 18; -fx-cursor: hand;" text="Drivers" />
                        </children>
                    </HBox>

                    <!-- Scrollable Table -->
                    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;                                        -fx-border-color: transparent; -fx-focus-color: transparent;                                        -fx-faint-focus-color: transparent;" VBox.vgrow="ALWAYS">
                        <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;                                      -fx-border-color: #E4EAF4; -fx-border-radius: 10; -fx-border-width: 0.8;">

                            <!-- Table Header -->
                            <HBox style="-fx-background-color: #F0F5FF; -fx-background-radius: 10 10 0 0;                                          -fx-padding: 8 10 8 10;                                          -fx-border-color: transparent transparent #D8E8FF transparent;                                          -fx-border-width: 1;">
                                <Label prefWidth="120.0" style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" text="Name" />
                                <Label prefWidth="140.0" style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" text="Email" />
                                <Label prefWidth="110.0" style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" text="Phone" />
                                <Label prefWidth="60.0" style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" text="Status" />
                                <Label style="-fx-text-fill: #1A6DBB; -fx-font-size: 11px; -fx-font-weight: bold;" text="Actions" />
                            </HBox>

                            <!-- Rows injected by controller -->
                            <VBox fx:id="usersContainer" spacing="0" />

                        </VBox>
                    </ScrollPane>
                    <HBox spacing="10">
                        <Button fx:id="btnBlock"
                                text="Block Selected User"
                                style="-fx-background-color: #1A6DBB; -fx-text-fill: white;
                   -fx-background-radius: 6; -fx-padding: 6 14;
                   -fx-font-size: 11px; -fx-cursor: hand;" />

                        <Button fx:id="btnUnBlock"
                                text="Unblock Selected User"
                                style="-fx-background-color: #1A6DBB; -fx-text-fill: white;
                   -fx-background-radius: 6; -fx-padding: 6 14;
                   -fx-font-size: 11px; -fx-cursor: hand;" />
                        <VBox.margin>
                            <Insets bottom="10"/>
                        </VBox.margin>
                    </HBox>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
