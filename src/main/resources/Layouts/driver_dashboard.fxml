<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #F7FAFF;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dynamic_ride_allocator.Controllers.DriverControllers.DriverDashboardController">

    <children>
        <HBox prefHeight="500.0" prefWidth="700.0">
            <children>

                <!-- ── SIDEBAR ── -->
                <VBox prefHeight="500.0" prefWidth="170.0" style="-fx-background-color: #1A3A5C;">
                    <Label prefHeight="54.0" prefWidth="189.0" style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-border-color: transparent transparent rgba(255,255,255,0.15) transparent;                                   -fx-border-width: 1; -fx-padding: 14 16 18 16;" text="🚗  Driver">
                        <font><Font size="10.0" /></font>
                    </Label>
                    <Label fx:id="btnHome" onMouseClicked="#btnHomeAction" prefWidth="170.0" style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; -fx-font-weight: bold;                                   -fx-background-color: rgba(255,255,255,0.15);                                   -fx-border-color: #5DB3FF transparent transparent transparent;                                   -fx-border-width: 0 0 0 3; -fx-padding: 10 16 10 13;" text="🏠  Home" />
                    <Label fx:id="btnAvailability" onMouseClicked="#btnAvailabilityAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="📡  Availability" />
                    <Label fx:id="btnRequests" onMouseClicked="#btnRequestsAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="📋  Ride Requests" />
                    <Label fx:id="btnCurrentRide" onMouseClicked="#btnCurrentRideAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="🚘  Current Ride" />
                    <Label fx:id="btnProfile" onMouseClicked="#btnProfileAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-padding: 10 16 10 16; -fx-cursor: hand;" text="👤  Profile" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Label onMouseClicked="#btnLogoutAction" prefWidth="170.0" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px; -fx-padding: 10 16 14 16; -fx-cursor: hand;" text="🚪  Logout" />
                </VBox>

                <!-- ── MAIN AREA ── -->
                <VBox prefHeight="500.0" prefWidth="530.0" style="-fx-background-color: #F7FAFF; -fx-padding: 20 20 20 20;">

                    <!-- Top Row: greeting + status badge -->
                    <HBox alignment="CENTER_LEFT">
                        <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                        <children>
                            <VBox HBox.hgrow="ALWAYS">
                                <Label style="-fx-text-fill: #1A3A5C; -fx-font-size: 15px; -fx-font-weight: bold;" text="Good morning, Bilal!" />
                                <Label style="-fx-text-fill: #999999; -fx-font-size: 12px;" text="Ready for rides today?" />
                            </VBox>
                            <HBox alignment="CENTER" spacing="6.0" style="-fx-background-color: #E8FAF2; -fx-background-radius: 20; -fx-padding: 6 14 6 14;">
                                <Label style="-fx-text-fill: #27A065; -fx-font-size: 9px;" text="●" />
                                <Label fx:id="tvStatusSmall" style="-fx-text-fill: #1A7A4A; -fx-font-size: 12px; -fx-font-weight: bold;" text="Online" />
                            </HBox>
                        </children>
                    </HBox>

                    <!-- Stat Cards Row -->
                    <HBox spacing="12.0">
                        <VBox.margin><Insets bottom="18.0" /></VBox.margin>
                        <children>
                            <VBox alignment="CENTER" prefHeight="72.0" prefWidth="160.0" style="-fx-background-color: #F0F6FF; -fx-background-radius: 10; -fx-padding: 14;">
                                <Label fx:id="tvTotalRides" style="-fx-text-fill: #1A6DBB; -fx-font-size: 26px; -fx-font-weight: bold;" text="0" />
                                <Label style="-fx-text-fill: #666666; -fx-font-size: 11px;" text="Today's Rides" />
                            </VBox>
                            <VBox alignment="CENTER" prefHeight="72.0" prefWidth="160.0" style="-fx-background-color: #F0F6FF; -fx-background-radius: 10; -fx-padding: 14;">
                                <Label fx:id="tvTotalEarnings" style="-fx-text-fill: #1A6DBB; -fx-font-size: 22px; -fx-font-weight: bold;" text="Rs 0" />
                                <Label style="-fx-text-fill: #666666; -fx-font-size: 11px;" text="Today's Earnings" />
                            </VBox>
                            <VBox alignment="CENTER" prefHeight="72.0" prefWidth="160.0" style="-fx-background-color: #E8FAF2; -fx-background-radius: 10; -fx-padding: 14;">
                                <Label fx:id="tvStatus" style="-fx-text-fill: #1A7A4A; -fx-font-size: 22px; -fx-font-weight: bold;" text="Online" />
                                <Label style="-fx-text-fill: #666666; -fx-font-size: 11px;" text="Status" />
                            </VBox>
                        </children>
                    </HBox>

                    <!-- Recent Earnings Title -->
                    <Label style="-fx-text-fill: #1A3A5C; -fx-font-size: 13px; -fx-font-weight: bold;" text="Recent Earnings">
                        <VBox.margin><Insets bottom="8.0" /></VBox.margin>
                    </Label>

                    <!-- ── Scrollable Earnings List ── -->
                    <ScrollPane fitToWidth="true" style="-fx-background: transparent;                                        -fx-background-color: transparent;                                        -fx-border-color: transparent;                                        -fx-focus-color: transparent;                                        -fx-faint-focus-color: transparent;" VBox.vgrow="ALWAYS">

                        <!-- Outer card wrapper -->
                        <VBox style="-fx-background-color: #FFFFFF;                                      -fx-background-radius: 10;                                      -fx-border-color: #E4EAF4;                                      -fx-border-radius: 10;                                      -fx-border-width: 0.8;                                      -fx-padding: 4 14 4 14;">

                            <!-- Controller injects rows here -->
                            <VBox fx:id="earningsContainer" spacing="0" />

                        </VBox>
                    </ScrollPane>

                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
